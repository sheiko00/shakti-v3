# PostgreSQL Settings
DB_USER=postgres
DB_PASSWORD=your_secure_db_password
DB_NAME=shakti_os

# Core URLs
APP_URL=https://app.shakti.beauty
NEXT_PUBLIC_API_URL=https://api.shakti.beauty/api
COOKIE_DOMAIN=.shakti.beauty

# Security
JWT_SECRET=your_super_secret_jwt_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here

# Google Cloud Storage (Assets Module)
GCS_BUCKET=your_gcs_bucket_name
GCS_KEY=your_gcs_key_path

# SMTP (Email Notifications)
SMTP_HOST=smtp.yourprovider.com
SMTP_USER=no-reply@shakti.beauty
SMTP_PASS=your_smtp_password

# Node Env
NODE_ENV=production
